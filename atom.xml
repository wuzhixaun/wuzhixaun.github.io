    <title>HTTP协议中PUT和POST使用区别</title>
    <link href="https://wuzhixaun.github.io/2020/04/18/HTTP%E5%8D%8F%E8%AE%AE%E4%B8%ADPUT%E5%92%8CPOST%E4%BD%BF%E7%94%A8%E5%8C%BA%E5%88%AB/"/>
    <id>https://wuzhixaun.github.io/2020/04/18/HTTP%E5%8D%8F%E8%AE%AE%E4%B8%ADPUT%E5%92%8CPOST%E4%BD%BF%E7%94%A8%E5%8C%BA%E5%88%AB/</id>
